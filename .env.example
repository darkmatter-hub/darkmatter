# DarkMatter Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to git

# ── Supabase (production storage) ──────────────────────────────
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_KEY=your-anon-key-here

# ── Internal API key (protects /api/agents and /api/commits) ───
# Generate any random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_KEY=your-random-secret-here

# ── Server ──────────────────────────────────────────────────────
PORT=3000
